FlightGear XML Additions for Control: 
  Add each using: 
  cat ~/FlightGear.app/Contents/Resources/data/Protocol/simulink_controls.xml
  echo "---"
  cat ~/FlightGear.app/Contents/Resources/data/Protocol/simulink_yoke.xml
  echo "---"
  cat ~/MAE_498/FlightGear.app/Contents/Resources/data/Protocol/simulink_instruments.xml
  
- Simulink Controls

<PropertyList>
 <generic>
  <input>
   <binary_mode>true</binary_mode>
   <chunk>
    <name>elevator</name>
    <type>float</type>
    <node>/controls/flight/elevator</node>
   </chunk>
   <chunk>
    <name>aileron</name>
    <type>float</type>
    <node>/controls/flight/aileron</node>
   </chunk>
   <chunk>
    <name>rudder</name>
    <type>float</type>
    <node>/controls/flight/rudder</node>
   </chunk>
   <chunk>
    <name>throttle</name>
    <type>float</type>
    <node>/controls/engines/engine[0]/throttle</node>
   </chunk>
   <chunk>
    <name>throttle_lever</name>
    <type>float</type>
    <node>/controls/engines/current-engine/throttle</node>
   </chunk>
  </input>
 </generic>
</PropertyList>

